# Required
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Access control: comma-separated Telegram user IDs
# Leave empty to allow all users (NOT recommended for production)
ALLOWED_USER_IDS=123456789

# Webhook mode (comment out for polling / local dev)
# WEBHOOK_URL=https://yourdomain.com/bot
# WEBHOOK_SECRET=your-random-secret

# LLM integration (optional — bot works without these)
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# Storage — must be a mounted volume in Docker
DATA_DIR=/data

# Embedding model (baked into Docker image)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Scheduling
SCHEDULER_TIMEZONE=UTC

# Suggestion engine defaults
COOLDOWN_DAYS=14
DBSCAN_EPSILON=0.3
DBSCAN_MIN_SAMPLES=2

# Logging
LOG_LEVEL=INFO
